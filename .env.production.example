# ═══════════════════════════════════════════════════
# WEMSTY BACKEND - PRODUCTION ENVIRONMENT VARIABLES
# ═══════════════════════════════════════════════════
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!

# ═══════════════════════════════════════════════════
# SERVER CONFIGURATION
# ═══════════════════════════════════════════════════

NODE_ENV=production
PORT=3001

# Frontend URLs allowed to access your API (CORS)
# Separate multiple origins with commas
ALLOWED_ORIGINS=https://wemsty.com,https://www.wemsty.com,https://app.wemsty.com

# ═══════════════════════════════════════════════════
# DATABASE - MONGODB ATLAS
# ═══════════════════════════════════════════════════

# Use the standard (non-SRV) connection string if SRV fails
# Format: mongodb://username:password@host1:27017,host2:27017,host3:27017/database?ssl=true&replicaSet=xxx&authSource=admin
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.risctut.mongodb.net/wemsty?retryWrites=true&w=majority

# ═══════════════════════════════════════════════════
# SECURITY - JWT SECRETS
# ═══════════════════════════════════════════════════
# Generate strong random strings for each secret
# Use: node generate-secrets.js to create new secrets

JWT_SECRET=<your-main-jwt-secret-min-64-chars>
JWT_ACCESS_SECRET=<your-access-token-secret-min-64-chars>
JWT_REFRESH_SECRET=<your-refresh-token-secret-min-64-chars>
JWT_EMAIL_SECRET=<your-email-verification-secret-min-64-chars>
JWT_RESET_SECRET=<your-password-reset-secret-min-64-chars>

# Token expiration times
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ═══════════════════════════════════════════════════
# EXTERNAL SERVICES
# ═══════════════════════════════════════════════════

# Algolia Search
ALGOLIA_APP_ID=<your-algolia-app-id>
ALGOLIA_ADMIN_KEY=<your-algolia-admin-key>

# Paystack Payments
PAYSTACK_SECRET_KEY=<your-paystack-secret-key>

# Cloudinary (for image uploads)
CLOUDINARY_CLOUD_NAME=<your-cloudinary-cloud-name>
CLOUDINARY_API_KEY=<your-cloudinary-api-key>
CLOUDINARY_API_SECRET=<your-cloudinary-api-secret>

# ═══════════════════════════════════════════════════
# EMAIL CONFIGURATION (for verification & notifications)
# ═══════════════════════════════════════════════════

# SMTP Configuration (use your email provider)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=<your-email-address>
EMAIL_PASS=<your-email-password-or-app-password>
EMAIL_FROM=Wemsty <noreply@wemsty.com>

# Or use a service like SendGrid, Mailgun, etc.
# SENDGRID_API_KEY=<your-sendgrid-api-key>

# ═══════════════════════════════════════════════════
# REDIS (for caching & sessions)
# ═══════════════════════════════════════════════════

REDIS_URL=redis://<your-redis-host>:6379
REDIS_PASSWORD=<your-redis-password-if-any>

# ═══════════════════════════════════════════════════
# KAFKA (for message streaming)
# ═══════════════════════════════════════════════════

KAFKA_BROKERS=<your-kafka-broker-host>:9092
KAFKA_CLIENT_ID=wemsty-backend
KAFKA_GROUP_ID=wemsty-group

# ═══════════════════════════════════════════════════
# SUPABASE (if using for storage or auth)
# ═══════════════════════════════════════════════════

SUPABASE_URL=<your-supabase-project-url>
SUPABASE_ANON_KEY=<your-supabase-anon-key>
SUPABASE_SERVICE_KEY=<your-supabase-service-key>

# ═══════════════════════════════════════════════════
# GOOGLE OAUTH (for Google Sign-In)
# ═══════════════════════════════════════════════════

GOOGLE_CLIENT_ID=<your-google-client-id>.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=<your-google-client-secret>

# ═══════════════════════════════════════════════════
# OPTIONAL: FEATURE FLAGS & CONFIGURATION
# ═══════════════════════════════════════════════════

# Enable/disable features
ENABLE_RATE_LIMITING=true
ENABLE_LOGGING=true
LOG_LEVEL=info

# API Configuration
MAX_FILE_SIZE=10485760  # 10MB in bytes
MAX_POST_LENGTH=5000

# Session Configuration
SESSION_SECRET=<your-session-secret>

# ═══════════════════════════════════════════════════
# MONITORING & ANALYTICS (Optional)
# ═══════════════════════════════════════════════════

# Sentry for error tracking
# SENTRY_DSN=<your-sentry-dsn>

# Analytics
# MIXPANEL_TOKEN=<your-mixpanel-token>
# GA_TRACKING_ID=<your-google-analytics-id>

# ═══════════════════════════════════════════════════
# DEPLOYMENT SPECIFIC
# ═══════════════════════════════════════════════════

# If behind a reverse proxy (nginx, etc.)
TRUST_PROXY=true

# Server location/region
SERVER_REGION=us-east-1

# Timezone
TZ=UTC